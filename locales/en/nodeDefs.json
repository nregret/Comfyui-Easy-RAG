{
  "RagPromptDocumentLoader": {
    "display_name": "EasyRAG - Document Loader",
    "description": "Load a document from ComfyUI input directory for RAG.",
    "outputs": {
      "0": { "name": "documents" },
      "1": { "name": "summary" }
    },
    "inputs": {
      "document": { "name": "document" }
    }
  },
  "RagPromptVectorStoreBuilder": {
    "display_name": "EasyRAG - Vector Store Builder (FAISS)",
    "description": "Build FAISS vector index from loaded documents.",
    "inputs": {
      "documents": { "name": "documents" },
      "index_list": { "name": "index_list" },
      "index_name": { "name": "Create Vector Store Name" },
      "embedding_model": { "name": "embedding_model" },
      "chunk_size": { "name": "chunk_size" },
      "chunk_overlap": { "name": "chunk_overlap" },
      "show_retrieval_log": { "name": "show_retrieval_log" },
      "unload_embedding_model_after_build": { "name": "unload_embedding_model_after_build" }
    },
    "outputs": {
      "0": { "name": "rag_index" },
      "1": { "name": "summary" }
    }
  },
  "RagPromptLMStudioChatAdvanced": {
    "display_name": "EasyRAG - LM Studio API (Advanced)",
    "description": "Chat node with optional RAG retrieval and image input.",
    "inputs": {
      "question": { "name": "question" },
      "base_url": { "name": "base_url" },
      "model": { "name": "model" },
      "system_prompt": { "name": "system_prompt" },
      "temperature": { "name": "temperature" },
      "max_tokens": { "name": "max_tokens" },
      "top_k": { "name": "top_k" },
      "stream": { "name": "stream" },
      "clear_vram_before_run": { "name": "clear_vram_before_run" },
      "unload_model_after_response": { "name": "unload_model_after_response" },
      "rag_index": { "name": "rag_index" },
      "image": { "name": "image" },
      "seed": { "name": "seed" }
    },
    "outputs": {
      "0": { "name": "answer" },
      "1": { "name": "context_used" },
      "2": { "name": "raw_response" }
    }
  },
  "RagPromptLMStudioChatSimple": {
    "display_name": "EasyRAG - LM Studio API (Simple)",
    "description": "Simplified chat node with optional RAG retrieval.",
    "inputs": {
      "question": { "name": "question" },
      "base_url": { "name": "base_url" },
      "model": { "name": "model" },
      "system_prompt": { "name": "system_prompt" },
      "clear_vram_before_run": { "name": "clear_vram_before_run" },
      "unload_model_after_response": { "name": "unload_model_after_response" },
      "rag_index": { "name": "rag_index" },
      "image": { "name": "image" },
      "seed": { "name": "seed" }
    },
    "outputs": {
      "0": { "name": "answer" }
    }
  },
  "RagPromptPrebuiltLoader": {
    "display_name": "Rag Prebuilt Loader",
    "description": "Select prebuilt datasets from local rag folder and ComfyUI/models/RAG/Original.",
    "inputs": {
      "document": { "name": "document" }
    },
    "outputs": {
      "0": { "name": "documents" },
      "1": { "name": "summary" }
    }
  }
}
